<!DOCTYPE html>
<html lang="en" class="scroll-smooth" data-theme="dark">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>{{ ir.header.name }} — {{ ir.header.title }}</title>
  <meta name="description"
    content="{{ ir.summary.paragraph }}" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
    rel="stylesheet" />
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            sans: ['var(--font-body)', 'system-ui', 'sans-serif'],
            mono: ['"JetBrains Mono"', 'monospace'],
          },
          colors: {
            base: 'var(--bg)',
            deep: 'var(--bg-deep)',
            elevated: 'var(--bg-elevated)',
            accent: 'var(--accent)',
            'accent-bright': 'var(--accent-bright)',
            fg: 'var(--fg)',
            muted: 'var(--fg-muted)',
          },
        },
      },
    };
  </script>
  <style>
    *,
    *::before,
    *::after {
      box-sizing: border-box;
    }

    /* ===== THEME TOKENS ===== */
    [data-theme="dark"] {
      --font-body: "Inter";
      --bg: #050506;
      --bg-deep: #020203;
      --bg-elevated: #0a0a0c;
      --fg: #EDEDEF;
      --fg-muted: #8A8F98;
      --fg-emphasis: #ffffff;
      --accent: #5E6AD2;
      --accent-bright: #6872D9;
      --accent-glow: rgba(94, 106, 210, 0.3);
      --border: rgba(255, 255, 255, 0.06);
      --border-hover: rgba(255, 255, 255, 0.10);
      --card-bg: linear-gradient(to bottom, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.02));
      --card-shadow: 0 0 0 1px rgba(255, 255, 255, 0.06), 0 2px 20px rgba(0, 0, 0, 0.4);
      --card-shadow-hover: 0 0 0 1px rgba(255, 255, 255, 0.1), 0 8px 40px rgba(0, 0, 0, 0.5), 0 0 80px rgba(94, 106, 210, 0.08);
      --pill-bg: rgba(255, 255, 255, 0.04);
      --pill-border: rgba(255, 255, 255, 0.06);
      --pill-hover-bg: rgba(94, 106, 210, 0.12);
      --pill-hover-border: rgba(94, 106, 210, 0.3);
      --divider: linear-gradient(to right, transparent, rgba(255, 255, 255, 0.08), transparent);
      --timeline-dot-bg: #0a0a0c;
      --timeline-dot-border: rgba(94, 106, 210, 0.5);
      --timeline-line: linear-gradient(to bottom, rgba(94, 106, 210, 0.4), rgba(94, 106, 210, 0.05));
      --progress-track: rgba(255, 255, 255, 0.06);
      --icon-bg: rgba(94, 106, 210, 0.1);
      --icon-border: rgba(94, 106, 210, 0.2);
      --nav-bg: rgba(5, 5, 6, 0.70);
      --nav-border: rgba(255, 255, 255, 0.06);
      --spotlight-color: rgba(94, 106, 210, 0.15);
      --separator: rgba(255, 255, 255, 0.10);
      --gradient-text-from: #ffffff;
      --gradient-text-to: rgba(255, 255, 255, 0.70);
      --btn-shadow: 0 0 0 1px rgba(94, 106, 210, 0.5), 0 2px 8px rgba(94, 106, 210, 0.25), inset 0 1px 0 0 rgba(255, 255, 255, 0.15);
      --btn-shadow-hover: 0 0 0 1px rgba(94, 106, 210, 0.6), 0 4px 16px rgba(94, 106, 210, 0.35), inset 0 1px 0 0 rgba(255, 255, 255, 0.2);
      --glow-1: 0 0 600px 300px rgba(94, 106, 210, 0.06), 0 0 300px 150px rgba(94, 106, 210, 0.04);
      --glow-2: 0 0 500px 250px rgba(100, 80, 190, 0.04);
      --glow-3: 0 0 400px 200px rgba(80, 100, 210, 0.03);
      --grid-opacity: 0.02;
      --scrollbar-track: #050506;
      --scrollbar-thumb: rgba(255, 255, 255, 0.1);
      --scrollbar-thumb-hover: rgba(255, 255, 255, 0.15);
      --twistbox-border: rgba(255, 255, 255, 0.06);
    }

    [data-theme="light"] {
      --font-body: "Plus Jakarta Sans";
      --bg: #F8FAFC;
      --bg-deep: #F1F5F9;
      --bg-elevated: #FFFFFF;
      --fg: #0F172A;
      --fg-muted: #64748B;
      --fg-emphasis: #0F172A;
      --accent: #4F46E5;
      --accent-bright: #6366F1;
      --accent-glow: rgba(79, 70, 229, 0.3);
      --border: #E2E8F0;
      --border-hover: #CBD5E1;
      --card-bg: #FFFFFF;
      --card-shadow: 0 4px 20px -2px rgba(79, 70, 229, 0.08), 0 1px 3px rgba(0, 0, 0, 0.06);
      --card-shadow-hover: 0 10px 30px -5px rgba(79, 70, 229, 0.15), 0 4px 6px -4px rgba(79, 70, 229, 0.08);
      --pill-bg: #F1F5F9;
      --pill-border: #E2E8F0;
      --pill-hover-bg: rgba(79, 70, 229, 0.08);
      --pill-hover-border: rgba(79, 70, 229, 0.3);
      --divider: linear-gradient(to right, transparent, #E2E8F0, transparent);
      --timeline-dot-bg: #FFFFFF;
      --timeline-dot-border: rgba(79, 70, 229, 0.5);
      --timeline-line: linear-gradient(to bottom, rgba(79, 70, 229, 0.3), rgba(79, 70, 229, 0.05));
      --progress-track: #E2E8F0;
      --icon-bg: rgba(79, 70, 229, 0.08);
      --icon-border: rgba(79, 70, 229, 0.15);
      --nav-bg: rgba(248, 250, 252, 0.80);
      --nav-border: #E2E8F0;
      --spotlight-color: rgba(79, 70, 229, 0.06);
      --separator: #E2E8F0;
      --gradient-text-from: #0F172A;
      --gradient-text-to: #334155;
      --btn-shadow: 0 4px 14px 0 rgba(79, 70, 229, 0.3);
      --btn-shadow-hover: 0 6px 20px 0 rgba(79, 70, 229, 0.4);
      --glow-1: 0 0 600px 300px rgba(79, 70, 229, 0.04), 0 0 300px 150px rgba(79, 70, 229, 0.03);
      --glow-2: 0 0 500px 250px rgba(124, 58, 237, 0.03);
      --glow-3: 0 0 400px 200px rgba(99, 102, 241, 0.03);
      --grid-opacity: 0;
      --scrollbar-track: #F8FAFC;
      --scrollbar-thumb: #CBD5E1;
      --scrollbar-thumb-hover: #94A3B8;
      --twistbox-border: #E2E8F0;
    }

    html {
      background: var(--bg-deep);
    }

    body {
      background: var(--bg);
      color: var(--fg);
      overflow-x: hidden;
      font-family: var(--font-body), system-ui, sans-serif;
      transition: background 0.3s ease, color 0.3s ease;
    }

    /* Grid overlay */
    .grid-overlay::after {
      content: '';
      position: fixed;
      inset: 0;
      opacity: var(--grid-opacity);
      pointer-events: none;
      z-index: 1;
      background-size: 64px 64px;
      background-image: linear-gradient(to right, rgba(255, 255, 255, 0.1) 1px, transparent 1px),
        linear-gradient(to bottom, rgba(255, 255, 255, 0.1) 1px, transparent 1px);
    }

    /* Spotlight on cards */
    .spotlight-card {
      position: relative;
      overflow: hidden;
    }

    .spotlight-card::before {
      content: '';
      position: absolute;
      width: 300px;
      height: 300px;
      border-radius: 50%;
      background: radial-gradient(circle, var(--spotlight-color) 0%, transparent 70%);
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.3s ease-out;
      transform: translate(-50%, -50%);
      z-index: 2;
    }

    .spotlight-card:hover::before {
      opacity: 1;
    }

    /* Scroll reveal */
    .reveal {
      opacity: 0;
      transform: translateY(24px);
      transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
        transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .reveal.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* Gradient text */
    .gradient-text {
      background: linear-gradient(to bottom, var(--gradient-text-from), var(--gradient-text-to));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .accent-gradient-text {
      background: linear-gradient(135deg, var(--accent), #818cf8, var(--accent));
      background-size: 200% 200%;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: shimmer 3s ease-in-out infinite;
    }

    @keyframes shimmer {

      0%,
      100% {
        background-position: 0% 50%;
      }

      50% {
        background-position: 100% 50%;
      }
    }

    /* Section divider */
    .section-divider {
      height: 1px;
      background: var(--divider);
    }

    /* Timeline */
    .timeline-line {
      position: absolute;
      left: 7px;
      top: 24px;
      bottom: 0;
      width: 1px;
      background: var(--timeline-line);
    }

    .timeline-dot {
      width: 15px;
      height: 15px;
      border-radius: 50%;
      background: var(--timeline-dot-bg);
      border: 2px solid var(--timeline-dot-border);
      box-shadow: 0 0 8px var(--accent-glow);
      flex-shrink: 0;
      position: relative;
      z-index: 2;
    }

    .timeline-dot-active {
      background: var(--accent);
      border-color: var(--accent);
      box-shadow: 0 0 12px var(--accent-glow);
    }

    /* Themed cards */
    .themed-card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      box-shadow: var(--card-shadow);
      transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1),
        box-shadow 0.3s cubic-bezier(0.16, 1, 0.3, 1),
        border-color 0.3s ease-out;
    }

    .themed-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--card-shadow-hover);
      border-color: var(--border-hover);
    }

    /* Skill pill */
    .skill-pill {
      background: var(--pill-bg);
      border: 1px solid var(--pill-border);
      transition: all 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .skill-pill:hover {
      background: var(--pill-hover-bg);
      border-color: var(--pill-hover-border);
      box-shadow: 0 0 16px rgba(94, 106, 210, 0.1);
    }

    /* Icon container */
    .icon-box {
      background: var(--icon-bg);
      border: 1px solid var(--icon-border);
    }

    /* Mobile nav */
    .mobile-nav {
      max-height: 0;
      overflow: hidden;
      opacity: 0;
      pointer-events: none;
      transition: max-height 0.3s cubic-bezier(0.16, 1, 0.3, 1),
        opacity 0.2s ease-out;
    }

    .mobile-nav.open {
      max-height: 300px;
      opacity: 1;
      pointer-events: auto;
    }

    /* Theme toggle button */
    .theme-toggle {
      width: 36px;
      height: 36px;
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--pill-bg);
      border: 1px solid var(--border);
      cursor: pointer;
      transition: all 0.2s ease-out;
    }

    .theme-toggle:hover {
      background: var(--pill-hover-bg);
      border-color: var(--border-hover);
    }

    .theme-toggle svg {
      width: 18px;
      height: 18px;
      transition: transform 0.3s ease, opacity 0.2s ease;
    }

    [data-theme="dark"] .icon-sun {
      display: block;
    }

    [data-theme="dark"] .icon-moon {
      display: none;
    }

    [data-theme="light"] .icon-sun {
      display: none;
    }

    [data-theme="light"] .icon-moon {
      display: block;
    }

    /* ===== MOBILE RESPONSIVE ===== */
    @media (max-width: 480px) {
      .hero-heading {
        font-size: 2.25rem !important;
        line-height: 1.1;
      }
      .hero-subtitle {
        font-size: 1rem !important;
      }
      .section-heading {
        font-size: 1.75rem !important;
      }
    }

    @media (max-width: 768px) {
      /* Disable card hover lift on touch — it sticks */
      .themed-card:hover {
        transform: none;
      }
      /* Slightly bigger tap targets for pills */
      .skill-pill {
        min-height: 36px;
        display: inline-flex;
        align-items: center;
      }
    }

    /* Reduce motion */
    @media (prefers-reduced-motion: reduce) {
      .reveal {
        opacity: 1;
        transform: none;
        transition: none;
      }

      .accent-gradient-text {
        animation: none;
      }

      .themed-card:hover {
        transform: none;
      }
    }

    /* Scrollbar */
    ::-webkit-scrollbar {
      width: 6px;
    }

    ::-webkit-scrollbar-track {
      background: var(--scrollbar-track);
    }

    ::-webkit-scrollbar-thumb {
      background: var(--scrollbar-thumb);
      border-radius: 3px;
    }

    ::-webkit-scrollbar-thumb:hover {
      background: var(--scrollbar-thumb-hover);
    }
  </style>

  {% if custom_css %}
  <style>{{ custom_css | safe }}</style>
  {% endif %}

  <!-- Prevent FOUC: apply saved theme before paint -->
  <script>
    (function () {
      var t = localStorage.getItem('theme') || 'dark';
      document.documentElement.setAttribute('data-theme', t);
    })();
  </script>
</head>

<body class="font-sans antialiased grid-overlay">

  <!-- ===== AMBIENT BACKGROUND ===== -->
  <div class="fixed inset-0 pointer-events-none z-0" style="background: var(--bg);">
    <div class="absolute top-[-20%] left-1/2 -translate-x-1/2 w-1 h-1 rounded-full" style="box-shadow: var(--glow-1);">
    </div>
    <div class="absolute top-[30%] -left-[10%] w-1 h-1 rounded-full" style="box-shadow: var(--glow-2);"></div>
    <div class="absolute top-[40%] -right-[5%] w-1 h-1 rounded-full" style="box-shadow: var(--glow-3);"></div>
  </div>

  <!-- ===== NAVIGATION ===== -->
  <nav class="fixed top-0 inset-x-0 z-50">
    <div class="backdrop-blur-xl border-b" style="background: var(--nav-bg); border-color: var(--nav-border);">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between">
        <a href="#" class="text-sm font-semibold tracking-tight text-fg hover:opacity-80 transition-opacity">
          {{ ir.header.name.split() | map('first') | join | upper }}
        </a>
        <!-- Desktop nav -->
        <div class="hidden md:flex items-center gap-6">
          <a href="#experience" class="text-sm text-muted hover:text-fg transition-colors duration-200">Experience</a>
          <a href="#skills" class="text-sm text-muted hover:text-fg transition-colors duration-200">Skills</a>
          <a href="#projects" class="text-sm text-muted hover:text-fg transition-colors duration-200">Projects</a>
          <button id="theme-toggle-desktop" class="theme-toggle" aria-label="Toggle theme">
            <svg class="icon-sun" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
            </svg>
            <svg class="icon-moon" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
            </svg>
          </button>
          <a href="mailto:{{ ir.header.email }}"
            class="text-sm px-4 py-1.5 rounded-lg bg-accent hover:bg-accent-bright text-white transition-all duration-200 active:scale-[0.98]"
            style="box-shadow: var(--btn-shadow);">
            Contact
          </a>
        </div>
        <!-- Mobile: toggle + hamburger -->
        <div class="flex md:hidden items-center gap-2">
          <button id="theme-toggle-mobile" class="theme-toggle" aria-label="Toggle theme">
            <svg class="icon-sun" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
            </svg>
            <svg class="icon-moon" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round"
                d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
            </svg>
          </button>
          <button id="menu-toggle" class="p-2 text-muted hover:text-fg transition-colors" aria-label="Toggle menu">
            <svg id="menu-icon" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="1.5"
              viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
            </svg>
            <svg id="close-icon" class="w-5 h-5 hidden" fill="none" stroke="currentColor" stroke-width="1.5"
              viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
            </svg>
          </button>
        </div>
      </div>
      <!-- Mobile dropdown -->
      <div id="mobile-nav" class="mobile-nav md:hidden backdrop-blur-xl px-6 pb-4"
        style="background: var(--nav-bg); border-top: 1px solid var(--nav-border);">
        <div class="flex flex-col gap-1 py-2">
          <a href="#experience" class="nav-link py-2 text-sm text-muted hover:text-fg transition-colors">Experience</a>
          <a href="#skills" class="nav-link py-2 text-sm text-muted hover:text-fg transition-colors">Skills</a>
          <a href="#projects" class="nav-link py-2 text-sm text-muted hover:text-fg transition-colors">Projects</a>
          <a href="mailto:{{ ir.header.email }}"
            class="mt-2 text-center text-sm px-4 py-2 rounded-lg bg-accent hover:bg-accent-bright text-white transition-all"
            style="box-shadow: var(--btn-shadow);">
            Contact
          </a>
        </div>
      </div>
    </div>
  </nav>

  <main class="relative z-10">

    <!-- ===== HERO ===== -->
    <section id="hero" class="pt-24 pb-16 sm:pt-32 sm:pb-20 md:pt-40 md:pb-28 px-4 sm:px-6">
      <div class="max-w-5xl mx-auto text-center">
        <div class="reveal">
          <span class="inline-block font-mono text-xs tracking-widest text-accent uppercase mb-6">
            {{ ir.header.title }}
          </span>
        </div>
        <h1
          class="reveal hero-heading text-4xl sm:text-5xl md:text-7xl lg:text-8xl font-semibold tracking-[-0.03em] leading-none gradient-text mb-6"
          style="transition-delay: 0.08s;">
          {{ ir.header.name }}
        </h1>
        <p class="reveal hero-subtitle text-base sm:text-lg md:text-xl text-muted max-w-2xl mx-auto leading-relaxed mb-8 sm:mb-10"
          style="transition-delay: 0.16s;">
          {{ ir.summary.paragraph }}
        </p>
        <div class="reveal flex flex-wrap items-center justify-center gap-4 text-sm" style="transition-delay: 0.24s;">
          <span class="text-muted">{{ ir.header.location }}</span>
          <span style="color: var(--separator);">|</span>
          <a href="mailto:{{ ir.header.email }}"
            class="text-muted hover:text-accent transition-colors">{{ ir.header.email }}</a>
          <span style="color: var(--separator);">|</span>
          <a href="https://{{ ir.header.linkedin }}" target="_blank" rel="noopener"
            class="text-muted hover:text-accent transition-colors">LinkedIn</a>
          <span style="color: var(--separator);">|</span>
          <a href="https://{{ ir.header.github }}" target="_blank" rel="noopener"
            class="text-muted hover:text-accent transition-colors">GitHub</a>
        </div>
      </div>
    </section>

    <div class="section-divider max-w-5xl mx-auto"></div>

    <!-- ===== SUMMARY CARDS ===== -->
    <section class="py-10 md:py-14 px-4 sm:px-6">
      <div class="max-w-5xl mx-auto">
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4 md:gap-6">
          {#- Summary card SVG icons — cycled by position -#}
          {%- set summary_icons = [
            '<svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 0 0 6 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0 1 18 16.5h-2.25m-7.5 0h7.5m-7.5 0-1 3m8.5-3 1 3m0 0 .5 1.5m-.5-1.5h-9.5m0 0-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6" /></svg>',
            '<svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" /></svg>',
            '<svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 0 0-2.455 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z" /></svg>'
          ] -%}
          {% for bullet in ir.summary.bullets %}
          <div class="reveal spotlight-card themed-card rounded-2xl p-6"{% if not loop.first %} style="transition-delay: {{ '%.2f' | format(loop.index0 * 0.08) }}s;"{% endif %}>
            <div class="w-10 h-10 rounded-xl icon-box flex items-center justify-center mb-4">
              {{ summary_icons[loop.index0 % summary_icons | length] | safe }}
            </div>
            <h3 class="text-sm font-semibold text-fg mb-2">{{ bullet.label }}</h3>
            <p class="text-sm text-muted leading-relaxed">
              {{ bullet.text }}
            </p>
          </div>
          {% endfor %}
        </div>
      </div>
    </section>

    <div class="section-divider max-w-5xl mx-auto"></div>

    <!-- ===== EXPERIENCE ===== -->
    <section id="experience" class="py-10 md:py-16 px-4 sm:px-6">
      <div class="max-w-5xl mx-auto">
        <div class="reveal mb-12 md:mb-16">
          <span class="font-mono text-xs tracking-widest text-accent uppercase">Career</span>
          <h2 class="section-heading text-2xl sm:text-3xl md:text-5xl font-semibold tracking-tight gradient-text mt-3">Professional Experience</h2>
        </div>

        {% for company in ir.experience %}
        {%- if company.company == "Sabbatical" %}
        {#- Sabbatical — skip rendering, it's a gap year -#}
        {%- elif loop.first %}
        {#- First company: timeline dot style -#}
        <div class="reveal mb-12">
          <div class="flex flex-col md:flex-row md:items-baseline md:justify-between mb-1">
            <h3 class="text-xl md:text-2xl font-semibold text-fg">{{ company.company }}</h3>
            <span class="font-mono text-xs text-muted mt-1 md:mt-0">{{ company.dates }}</span>
          </div>
          {% if company.description %}
          <p class="text-sm text-muted mb-8">{{ company.location }} &middot; {{ company.description }}</p>
          {% else %}
          <p class="text-sm text-muted mb-8">{{ company.location }}</p>
          {% endif %}

          <div class="space-y-8 ml-1">
            {% for role in company.roles %}
            <div class="relative pl-8">
              {%- if not loop.last %}
              <div class="timeline-line"></div>
              {%- endif %}
              <div class="absolute left-0 top-1.5 timeline-dot{% if loop.first %} timeline-dot-active{% endif %}"></div>
              <div class="flex flex-col md:flex-row md:items-baseline md:justify-between mb-2">
                <h4 class="text-base font-semibold text-fg">{{ role.title }}</h4>
                <span class="font-mono text-xs text-muted">{{ role.dates }}</span>
              </div>
              {%- if role.description %}
              <p class="text-sm text-muted/80 italic mb-3">{{ role.description }}</p>
              {%- endif %}
              {%- if role.bullets %}
              <ul class="space-y-2">
                {% for bullet in role.bullets %}
                <li class="text-sm text-muted leading-relaxed">
                  {%- if bullet.label %}
                  <span class="text-fg font-medium">{{ bullet.label }}:</span> {{ bullet.text }}
                  {%- else %}
                  {{ bullet.text }}
                  {%- endif %}
                </li>
                {% endfor %}
              </ul>
              {%- endif %}
            </div>
            {% endfor %}
          </div>
        </div>
        {%- else %}
        {#- Non-first, non-sabbatical companies: left border style -#}
        <div class="reveal">
          <div class="section-divider mb-10"></div>
          <div class="flex flex-col md:flex-row md:items-baseline md:justify-between mb-1">
            <h3 class="text-xl md:text-2xl font-semibold text-fg">{{ company.company }}</h3>
            <span class="font-mono text-xs text-muted mt-1 md:mt-0">{{ company.dates }}</span>
          </div>
          <p class="text-sm text-muted mb-6">{{ company.location }}</p>
          {% for role in company.roles %}
          <div class="pl-4 border-l" style="border-color: var(--twistbox-border);">
            <h4 class="text-base font-semibold text-fg mb-3">{{ role.title }}</h4>
            {%- if role.description %}
            <p class="text-sm text-muted/80 italic mb-3">{{ role.description }}</p>
            {%- endif %}
            {%- if role.bullets %}
            <ul class="space-y-2">
              {% for bullet in role.bullets %}
              <li class="text-sm text-muted leading-relaxed">
                {%- if bullet.label %}
                <span class="text-fg font-medium">{{ bullet.label }}:</span> {{ bullet.text }}
                {%- else %}
                {{ bullet.text }}
                {%- endif %}
              </li>
              {% endfor %}
            </ul>
            {%- endif %}
          </div>
          {% endfor %}
        </div>
        {%- endif %}
        {% endfor %}
      </div>
    </section>

    <div class="section-divider max-w-5xl mx-auto"></div>

    <!-- ===== SKILLS ===== -->
    <section id="skills" class="py-10 md:py-16 px-4 sm:px-6">
      <div class="max-w-5xl mx-auto">
        <div class="reveal mb-12 md:mb-16">
          <span class="font-mono text-xs tracking-widest text-accent uppercase">Toolkit</span>
          <h2 class="section-heading text-2xl sm:text-3xl md:text-5xl font-semibold tracking-tight gradient-text mt-3">Skills &amp; Technologies
          </h2>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-4">
          {% for skill in ir.skills %}
          <div class="reveal spotlight-card themed-card rounded-2xl p-6"{% if not loop.first %} style="transition-delay: {{ '%.2f' | format(loop.index0 * 0.04 + 0.08) }}s;"{% endif %}>
            <span class="font-mono text-xs tracking-widest text-accent uppercase">{{ skill.category }}</span>
            <div class="flex flex-wrap gap-2 mt-4">
              {%- for pill in parse_skill_items(skill.items) %}
              <span class="skill-pill px-3 py-1.5 rounded-full text-xs text-fg">{{ pill }}</span>
              {%- endfor %}
            </div>
          </div>
          {% endfor %}
        </div>
      </div>
    </section>

    <div class="section-divider max-w-5xl mx-auto"></div>

    <!-- ===== PROJECTS ===== -->
    <section id="projects" class="py-10 md:py-16 px-4 sm:px-6">
      <div class="max-w-5xl mx-auto">
        <div class="reveal mb-12 md:mb-16">
          <span class="font-mono text-xs tracking-widest text-accent uppercase">Side Projects</span>
          <h2 class="section-heading text-2xl sm:text-3xl md:text-5xl font-semibold tracking-tight gradient-text mt-3">Personal Projects</h2>
        </div>

        {#- SVG icons rotate through projects -#}
        {%- set project_icons = [
          '<svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25a2.25 2.25 0 0 1-2.25-2.25v-2.25Z" /></svg>',
          '<svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 0 1 5.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 0 0-1.134-.175 2.31 2.31 0 0 1-1.64-1.055l-.822-1.316a2.192 2.192 0 0 0-1.736-1.039 48.774 48.774 0 0 0-5.232 0 2.192 2.192 0 0 0-1.736 1.039l-.821 1.316Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 1 1-9 0 4.5 4.5 0 0 1 9 0ZM18.75 10.5h.008v.008h-.008V10.5Z" /></svg>',
          '<svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 0 0-2.455 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z" /></svg>',
          '<svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5" /></svg>'
        ] -%}
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6">
          {% for project in ir.projects %}
          <a href="{{ project.url }}" target="_blank" rel="noopener"
            class="reveal spotlight-card themed-card group rounded-2xl p-6 md:p-8 block no-underline"
            {%- if not loop.first %} style="transition-delay: {{ '%.2f' | format(loop.index0 * 0.08) }}s;"{% endif %}>
            <div class="flex items-start justify-between mb-4">
              <div class="w-10 h-10 rounded-xl icon-box flex items-center justify-center">
                {{ project_icons[loop.index0 % project_icons | length] | safe }}
              </div>
              <svg
                class="w-4 h-4 text-muted group-hover:text-accent transition-all duration-200 group-hover:translate-x-0.5 group-hover:-translate-y-0.5"
                fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 19.5 15-15m0 0H8.25m11.25 0v11.25" />
              </svg>
            </div>
            <h3 class="text-lg font-semibold text-fg mb-2 group-hover:text-accent transition-colors">{{ project.name }}</h3>
            <p class="text-sm text-muted leading-relaxed mb-4">
              {{ project.description }}
            </p>
            <div class="flex flex-wrap gap-1.5">
              {% for tech in project.technologies %}
              <span class="skill-pill px-2 py-1 rounded-full text-[11px] text-muted">{{ tech }}</span>
              {% endfor %}
            </div>
          </a>
          {% endfor %}
        </div>
      </div>
    </section>

    <div class="section-divider max-w-5xl mx-auto"></div>

    <!-- ===== EDUCATION ===== -->
    <section class="py-10 md:py-14 px-4 sm:px-6">
      <div class="max-w-5xl mx-auto">
        <div class="reveal flex flex-col md:flex-row md:items-center md:justify-between">
          <div>
            <span class="font-mono text-xs tracking-widest text-accent uppercase">Education</span>
            <h3 class="text-xl font-semibold text-fg mt-2">{{ ir.education.degree }}</h3>
            <p class="text-sm text-muted mt-1">{{ ir.education.institution }}</p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <!-- ===== FOOTER ===== -->
  <footer class="py-10 px-4 sm:px-6 relative z-10" style="background: var(--bg); border-top: 1px solid var(--border);">
    <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
      <span class="text-xs text-muted">&copy; {{ current_year }} {{ ir.header.name }}</span>
      <div class="flex items-center gap-6">
        <a href="mailto:{{ ir.header.email }}" class="text-xs text-muted hover:text-accent transition-colors">Email</a>
        <a href="https://{{ ir.header.linkedin }}" target="_blank" rel="noopener"
          class="text-xs text-muted hover:text-accent transition-colors">LinkedIn</a>
        <a href="https://{{ ir.header.github }}" target="_blank" rel="noopener"
          class="text-xs text-muted hover:text-accent transition-colors">GitHub</a>
      </div>
    </div>
  </footer>

  <script>
    // --- Theme toggle ---
    function setTheme(theme) {
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('theme', theme);
    }
    function toggleTheme() {
      const current = document.documentElement.getAttribute('data-theme');
      setTheme(current === 'dark' ? 'light' : 'dark');
    }
    document.getElementById('theme-toggle-desktop').addEventListener('click', toggleTheme);
    document.getElementById('theme-toggle-mobile').addEventListener('click', toggleTheme);

    // --- Scroll reveal ---
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });
    document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

    // --- Spotlight tracking ---
    document.querySelectorAll('.spotlight-card').forEach(card => {
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        card.style.setProperty('--spot-x', (e.clientX - rect.left) + 'px');
        card.style.setProperty('--spot-y', (e.clientY - rect.top) + 'px');
      });
    });
    const spotStyle = document.createElement('style');
    spotStyle.textContent = `.spotlight-card::before { left: var(--spot-x, 50%); top: var(--spot-y, 50%); }`;
    document.head.appendChild(spotStyle);

    // --- Hero parallax (disabled on touch/small screens for perf) ---
    const hero = document.getElementById('hero');
    const isMobile = window.matchMedia('(max-width: 768px)').matches || 'ontouchstart' in window;
    if (hero && !isMobile && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      window.addEventListener('scroll', () => {
        const f = Math.min(window.scrollY / 600, 1);
        hero.style.opacity = 1 - f;
        hero.style.transform = `translateY(${window.scrollY * 0.15}px) scale(${1 - f * 0.05})`;
      }, { passive: true });
    }

    // --- Mobile menu ---
    const toggle = document.getElementById('menu-toggle');
    const mobileNav = document.getElementById('mobile-nav');
    const menuIcon = document.getElementById('menu-icon');
    const closeIcon = document.getElementById('close-icon');
    toggle.addEventListener('click', () => {
      const isOpen = mobileNav.classList.toggle('open');
      menuIcon.classList.toggle('hidden', isOpen);
      closeIcon.classList.toggle('hidden', !isOpen);
    });
    mobileNav.querySelectorAll('.nav-link').forEach(link => {
      link.addEventListener('click', () => {
        mobileNav.classList.remove('open');
        menuIcon.classList.remove('hidden');
        closeIcon.classList.add('hidden');
      });
    });
  </script>
</body>

</html>
